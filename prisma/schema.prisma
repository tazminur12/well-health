generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CUSTOMER
  ADMIN
  SUPPORT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum OfferBadge {
  SALE
  FLASH
  BUNDLE
  CLEARANCE
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

enum BlogCategory {
  HEALTH_TIPS
  PRODUCT_GUIDES
  NUTRITION
  COMPANY_NEWS
}

model User {
  id          String     @id @db.Uuid
  email       String     @unique
  name        String?
  phone       String?
  role        Role       @default(CUSTOMER)
  status      UserStatus @default(ACTIVE)
  notes       String?
  isVip       Boolean    @default(false) @map("is_vip")
  avatarUrl   String?    @map("avatar_url")
  staffRoleId String?    @map("staff_role_id")
  staffRole   StaffRole? @relation(fields: [staffRoleId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  invitesSent StaffInvite[] @relation("InviteSender")
  blogPosts   BlogPost[]
  reviews     ProductReview[]

  @@index([role])
  @@index([status])
  @@index([staffRoleId])
  @@map("users")
}

model StaffRole {
  id          String        @id @default(cuid())
  name        String        @unique
  slug        String        @unique
  description String?
  /// Maps to system access: ADMIN (full panel), SUPPORT (limited), CUSTOMER (storefront)
  accessLevel Role          @map("access_level")
  isSystem    Boolean       @default(false) @map("is_system")
  /// Module keys from ADMIN_PERMISSIONS (e.g. products, orders, chat)
  permissions String[]      @default([])
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  users       User[]
  invites     StaffInvite[]

  @@index([accessLevel])
  @@map("staff_roles")
}

model StaffInvite {
  id          String       @id @default(cuid())
  email       String
  name        String?
  roleId      String       @map("role_id")
  role        StaffRole    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  tokenHash   String       @unique @map("token_hash")
  status      InviteStatus @default(PENDING)
  invitedById String?      @db.Uuid @map("invited_by_id")
  invitedBy   User?        @relation("InviteSender", fields: [invitedById], references: [id], onDelete: SetNull)
  expiresAt   DateTime     @map("expires_at")
  acceptedAt  DateTime?    @map("accepted_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([email, status])
  @@index([roleId])
  @@map("staff_invites")
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  products    Product[]

  @@index([isActive, sortOrder])
  @@map("categories")
}

model Product {
  id                 String        @id @default(cuid())
  name               String
  nameBn             String?       @map("name_bn")
  slug               String        @unique
  categoryId         String        @map("category_id")
  category           Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brand              String        @default("Well Health")
  sku                String        @unique
  barcode            String?
  price              Decimal       @db.Decimal(12, 2)
  compareAtPrice     Decimal?      @map("compare_at_price") @db.Decimal(12, 2)
  costPrice          Decimal?      @map("cost_price") @db.Decimal(12, 2)
  offerEnabled       Boolean       @default(false) @map("offer_enabled")
  offerLabel         String?       @map("offer_label")
  discountPercent    Decimal?      @map("discount_percent") @db.Decimal(5, 2)
  offerPrice         Decimal?      @map("offer_price") @db.Decimal(12, 2)
  offerStartsAt      DateTime?     @map("offer_starts_at")
  offerEndsAt        DateTime?     @map("offer_ends_at")
  offerBadge         OfferBadge?   @map("offer_badge")
  stock              Int           @default(0)
  lowStockThreshold  Int           @default(10) @map("low_stock_threshold")
  unit               String        @default("Bottle")
  packSize           String?       @map("pack_size")
  servingSize        String?       @map("serving_size")
  shortDescription   String        @map("short_description")
  description        String
  descriptionBn      String?       @map("description_bn")
  ingredients        String?
  usageInstructions  String?       @map("usage_instructions")
  warnings           String?
  tags               String[]      @default([])
  metaTitle          String?       @map("meta_title")
  metaDescription    String?       @map("meta_description")
  featured           Boolean       @default(false)
  labTested          Boolean       @default(false) @map("lab_tested")
  doctorRecommended  Boolean       @default(false) @map("doctor_recommended")
  status             ProductStatus @default(DRAFT)
  imageTone          String?       @map("image_tone")
  imageCount         Int           @default(0) @map("image_count")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  images             ProductImage[]
  reviews            ProductReview[]

  @@index([categoryId])
  @@index([status])
  @@index([featured])
  @@index([offerEnabled])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  publicId  String?  @map("public_id")
  alt       String?
  sortOrder Int      @default(0) @map("sort_order")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([productId])
  @@map("product_images")
}

model BlogPost {
  id               String       @id @default(cuid())
  title            String
  slug             String       @unique
  excerpt          String
  content          String
  category         BlogCategory @default(HEALTH_TIPS)
  tags             String[]     @default([])
  status           BlogStatus   @default(DRAFT)
  featured         Boolean      @default(false)
  featuredImageUrl String?      @map("featured_image_url")
  metaTitle        String?      @map("meta_title")
  metaDescription  String?      @map("meta_description")
  authorId         String?      @db.Uuid @map("author_id")
  author           User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorName       String?      @map("author_name")
  views            Int          @default(0)
  publishedAt      DateTime?    @map("published_at")
  scheduledAt      DateTime?    @map("scheduled_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@index([status])
  @@index([category])
  @@index([featured])
  @@index([publishedAt])
  @@index([authorId])
  @@map("blog_posts")
}

model HeroSlide {
  id               String   @id @default(cuid())
  imageUrl         String   @map("image_url")
  alt              String
  linkUrl          String?  @map("link_url")
  headline         String?
  subheading       String?
  primaryCtaText   String?  @map("primary_cta_text")
  primaryCtaLink   String?  @map("primary_cta_link")
  secondaryCtaText String?  @map("secondary_cta_text")
  secondaryCtaLink String?  @map("secondary_cta_link")
  sortOrder        Int      @default(0) @map("sort_order")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("hero_slides")
}

model TrustBadge {
  id          String   @id @default(cuid())
  iconKey     String   @map("icon_key")
  title       String
  description String
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("trust_badges")
}

model FaqItem {
  id        String   @id @default(cuid())
  question  String
  answer    String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("faq_items")
}

/// Keyed CMS documents: about_home, site_assets, store_settings, etc.
model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("site_settings")
}

enum AdminNotificationType {
  ORDER
  PRODUCT
  CUSTOMER
  SYSTEM
  BLOG
}

model AdminNotification {
  id        String                @id @default(cuid())
  type      AdminNotificationType @default(SYSTEM)
  title     String
  message   String
  href      String?
  isRead    Boolean               @default(false) @map("is_read")
  meta      Json?
  createdAt DateTime              @default(now()) @map("created_at")
  updatedAt DateTime              @updatedAt @map("updated_at")

  @@index([isRead, createdAt])
  @@index([createdAt])
  @@map("admin_notifications")
}

enum CouponType {
  PERCENT
  FIXED
}

model Coupon {
  id               String       @id @default(cuid())
  code             String       @unique
  name             String
  description      String?
  type             CouponType   @default(PERCENT)
  value            Decimal      @db.Decimal(12, 2)
  minOrderAmount   Decimal?     @map("min_order_amount") @db.Decimal(12, 2)
  maxDiscount      Decimal?     @map("max_discount") @db.Decimal(12, 2)
  usageLimit       Int?         @map("usage_limit")
  usageCount       Int          @default(0) @map("usage_count")
  perCustomerLimit Int?         @map("per_customer_limit")
  startsAt         DateTime?    @map("starts_at")
  endsAt           DateTime?    @map("ends_at")
  isActive         Boolean      @default(true) @map("is_active")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@index([isActive, startsAt, endsAt])
  @@index([code])
  @@map("coupons")
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model ProductReview {
  id            String       @id @default(cuid())
  productId     String       @map("product_id")
  product       Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId        String?      @db.Uuid @map("user_id")
  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerName  String       @map("customer_name")
  customerEmail String?      @map("customer_email")
  rating        Int
  title         String?
  comment       String
  status        ReviewStatus @default(PENDING)
  isFeatured    Boolean      @default(false) @map("is_featured")
  adminReply    String?      @map("admin_reply")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@index([productId])
  @@index([status, createdAt])
  @@index([isFeatured])
  @@index([rating])
  @@map("product_reviews")
}

model ShippingZone {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String?
  /// Cities / areas covered (e.g. Dhaka Metro, Gulshan, Banani)
  areas           String   @default("")
  baseFee         Decimal  @map("base_fee") @db.Decimal(12, 2)
  freeShippingMin Decimal? @map("free_shipping_min") @db.Decimal(12, 2)
  etaMinDays      Int      @default(1) @map("eta_min_days")
  etaMaxDays      Int      @default(3) @map("eta_max_days")
  codAvailable    Boolean  @default(true) @map("cod_available")
  isActive        Boolean  @default(true) @map("is_active")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("shipping_zones")
}

model ShippingCourier {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  contactPhone String?  @map("contact_phone")
  trackingUrl  String?  @map("tracking_url")
  notes        String?
  isActive     Boolean  @default(true) @map("is_active")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("shipping_couriers")
}

enum ContactMessageStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

model ContactMessage {
  id         String               @id @default(cuid())
  name       String
  phone      String
  email      String
  subject    String
  message    String               @db.Text
  status     ContactMessageStatus @default(NEW)
  adminNotes String?              @map("admin_notes") @db.Text
  source     String               @default("contact") // contact | home
  repliedAt  DateTime?            @map("replied_at")
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([createdAt])
  @@map("contact_messages")
}

enum MarketingChannel {
  EMAIL
  SMS
}

enum MarketingAudience {
  ALL_CUSTOMERS
  VIP
  CUSTOM
}

enum MarketingCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

model MarketingCampaign {
  id              String                   @id @default(cuid())
  name            String
  channel         MarketingChannel
  audience        MarketingAudience        @default(ALL_CUSTOMERS)
  /// Subject line for email campaigns
  subject         String?
  /// Email HTML body or SMS text body
  body            String
  /// Manual emails / phones when audience = CUSTOM (newline or comma separated)
  customRecipients String?                 @map("custom_recipients") @db.Text
  status          MarketingCampaignStatus  @default(DRAFT)
  scheduledAt     DateTime?                @map("scheduled_at")
  sentAt          DateTime?                @map("sent_at")
  recipientCount  Int                      @default(0) @map("recipient_count")
  successCount    Int                      @default(0) @map("success_count")
  failureCount    Int                      @default(0) @map("failure_count")
  lastError       String?                  @map("last_error")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")

  @@index([channel, status, createdAt])
  @@index([status, scheduledAt])
  @@map("marketing_campaigns")
}
